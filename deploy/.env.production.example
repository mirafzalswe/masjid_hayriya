# ══════════════════════════════════════════════════════
#   Masjid Xayriya — PRODUCTION konfiguratsiya namunasi
#
#   Bu faylni nusxalang: cp deploy/.env.production.example /opt/masjid_hayria/.env
#   So'ng <PLACEHOLDER>'larni real qiymatlarga to'ldiring.
#   `chmod 600 /opt/masjid_hayria/.env`
#
#   ⚠ HECH QACHON real qiymatlar bilan to'ldirilgan .env'ni git'ga commit qilmang.
# ══════════════════════════════════════════════════════

# ─── Django ───────────────────────────────────────────
# Generatsiya:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=<GENERATE_WITH_SECRETS_TOKEN_URLSAFE_50>

DEBUG=False

# IP yoki domen ro'yxati
ALLOWED_HOSTS=139.59.130.53,localhost,127.0.0.1

# HTTP-only deployment (domen yo'q) → False
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_PROTO=False

# CSRF uchun ruxsat etilgan origin'lar
CSRF_TRUSTED_ORIGINS=http://139.59.130.53

# ─── Logging ──────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO

# ─── Telegram bot ─────────────────────────────────────
# @BotFather → /newbot → tokenni shu yerga qo'ying
TELEGRAM_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>

# Webhook rejimida ishlatiladi (polling uchun shart emas)
# WEBHOOK_SECRET=
