# ══════════════════════════════════════════════════════
#   Masjid Xayriya — Konfiguratsiya
#   Bu faylni `.env` nomi bilan saqlang.
#   ⚠ HECH QACHON git ga qo'shmang.
# ══════════════════════════════════════════════════════

# ─── Django ───────────────────────────────────────────
# `python -c "import secrets; print(secrets.token_urlsafe(50))"`
SECRET_KEY=

DEBUG=True
# Production uchun: domeningiz, masalan:
# ALLOWED_HOSTS=xayriya.example.com,www.xayriya.example.com
ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=https://xayriya.example.com

# ─── Logging ──────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO

# ─── Telegram bot (bot/main.py) ───────────────────────
# @BotFather → /newbot → tokenni shu yerga qo'ying
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Webhook rejimida ishlatiladi. Production uchun majburiy.
# Tasodifiy qiymat:
# `python -c "import secrets; print(secrets.token_urlsafe(32))"`
WEBHOOK_SECRET=
